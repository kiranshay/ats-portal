rules_version = '2';

// PSM Generator — Firebase Storage security rules
//
// Session 14 (2026-04-14): first real Storage rules on this bucket. Default
// rules were `allow read, write: if false` — blocks every client read of
// worksheet PDFs uploaded by Session 12's migration. This file opens
// /worksheets/* for any authenticated allowlisted user (tutor/admin/student/
// parent) so pdf.js can render them inline in SubmissionEditor.
//
// Scope note: worksheets are NOT per-student. The same PDF is assigned to
// many students, so there is no studentId path segment to gate on. This is
// intentionally a weaker gate than Firestore's canReadStudent() — any
// allowlisted role can fetch any worksheet PDF. For the 51-user pilot this
// matches the effective access level of WS_RAW (baked into the bundle).
// Public launch would require per-user signed URLs via a Cloud Function.
//
// Source of truth: docs/superpowers/specs/2026-04-14-session-14-submission-editor-design.md

// Session 14 final rule: public read on /worksheets/**, default-deny
// everything else.
//
// Why public read: pdf.js fetches PDF URLs via plain fetch() without
// carrying Firebase Auth tokens. An authenticated rule (request.auth !=
// null) rejects these fetches even when the user is signed in, because
// the request headers don't include the Firebase ID token. The two
// alternatives — loading the Firebase Storage JS SDK to call
// getDownloadURL() on every render, or generating per-upload download
// tokens and embedding them in catalog URLs — both add meaningful
// complexity for worksheets whose content is not proprietary: they are
// ATS-branded variants of public CollegeBoard practice questions. The
// business moat is the tutoring, not the PDFs.
//
// Admin SDK writes bypass these rules (they use service credentials),
// so Session 12's upload path and any future admin-side writes continue
// to work unchanged. Everything outside /worksheets/ stays default-deny.
//
// For per-user tracked access (DRM, watermarking, download audit logs),
// swap this for a Cloud Function that mints short-lived signed URLs. Not
// Session 14's problem.

service firebase.storage {
  match /b/{bucket}/o {

    match /worksheets/{file=**} {
      allow read: if true;
      allow write: if false;  // admin SDK only
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
