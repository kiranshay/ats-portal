{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "firestore.rules",
      "app.jsx",
      "build_index.py",
      "embed.js",
      "shell_head.html",
      "shell_tail.html",
      ".git/**",
      ".claude/**",
      "node_modules/**",
      "**/*.py",
      "**/*.jsx",
      "**/*.md"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache"
          }
        ]
      }
    ]
  }
}
