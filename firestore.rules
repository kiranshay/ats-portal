rules_version = '2';

// PSM Generator — Firestore security rules
//
// Access model (Phase 2 — per-student docs + legacy blob for customAssignments):
//   - /allowlist/{email}            admin-only
//   - /psm-data/main                tutor/admin only (legacy blob; houses
//                                   customAssignments and, during the
//                                   DUAL_WRITE_GRACE window, a mirror of
//                                   students[] for rollback)
//   - /students/{studentId}         tutor/admin read+write; linked
//                                   student/parent read-only
//   - /students/{id}/_private/info  tutor/admin only (notes)
//   - /students/{id}/submissions/*  tutor/admin full; linked student
//                                   can create drafts and transition
//                                   draft -> submitted on their own attempts
//
// Session 7 (2026-04-14) retired the @affordabletutoringsolutions.org
// workspace gate. Auth is now allowlist-only.
//
// Source of truth: docs/PHASE_2_SESSION_1.md · docs/PHASE_2_SESSION_7.md

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Identity helpers ─────────────────────────────────────────────────

    function emailKey() {
      return request.auth.token.email.lower();
    }

    function isAllowlisted() {
      return request.auth != null
        && request.auth.token.email_verified == true
        && exists(/databases/$(database)/documents/allowlist/$(emailKey()))
        && get(/databases/$(database)/documents/allowlist/$(emailKey())).data.active == true;
    }

    function allowlistRole() {
      return get(/databases/$(database)/documents/allowlist/$(emailKey())).data.role;
    }

    function allowlistStudentIds() {
      return get(/databases/$(database)/documents/allowlist/$(emailKey())).data.studentIds;
    }

    function isAllowlistAdmin() {
      return isAllowlisted() && allowlistRole() == 'admin';
    }

    function isTutorOrAdmin() {
      return isAllowlisted() && allowlistRole() in ['tutor', 'admin'];
    }

    function isLinkedToStudent(studentId) {
      return isAllowlisted()
        && allowlistRole() in ['student', 'parent']
        && studentId in allowlistStudentIds();
    }

    function canReadStudent(studentId) {
      return isTutorOrAdmin() || isLinkedToStudent(studentId);
    }

    // ── Allowlist collection ─────────────────────────────────────────────

    match /allowlist/{email} {
      // Any authenticated user can read their OWN entry to resolve their
      // role during sign-in. List (enumerate collection) and writes remain
      // admin-only. Self-read is the fix for the Session 7 sign-in bug
      // where non-admin users hit permission-denied on getAllowlistEntry.
      allow get: if request.auth != null
        && request.auth.token.email_verified == true
        && emailKey() == email;
      allow list, write: if isAllowlistAdmin();
    }

    // ── questionKeys (answer bank) — Session 15 ─────────────────────────
    // Per-CB-question-ID answer documents populated by the Session 12
    // extraction script via Admin SDK. Tutor/admin can read individual
    // docs for debug and audit; students and parents NEVER read this
    // collection (that would leak the answer key to the test-taker).
    //
    // Grading is server-side — the onSubmissionSubmit Cloud Function
    // uses the Admin SDK, which bypasses these rules, to join responses
    // against questionKeys and write only the per-question result back
    // to the submission doc. The student sees their score, never the key.
    //
    // `get` not `read`: tutor clients can fetch a specific doc by id
    // but cannot enumerate the 1,067-doc collection. Tighter default;
    // widen to `read` only if a future session adds a tutor-side
    // browse UI for the answer bank. The extraction script and the
    // grader trigger both use Admin SDK and are unaffected by this.
    match /questionKeys/{questionId} {
      allow get:   if isTutorOrAdmin();
      allow write: if false;
    }

    // ── Legacy blob ──────────────────────────────────────────────────────
    // Houses customAssignments permanently and mirrors students[] during
    // the DUAL_WRITE_GRACE window. Students/parents never read this doc
    // under the Phase 2 client — they read /students/{id} directly.
    match /psm-data/main {
      allow read, write: if isTutorOrAdmin();
    }

    // ── Per-student docs ─────────────────────────────────────────────────

    match /students/{studentId} {
      allow read:  if canReadStudent(studentId);
      allow write: if isTutorOrAdmin();

      // Notes live here because Firestore rules cannot gate individual
      // fields within a doc — splitting is the only way to hide them
      // from the student's own read of /students/{id}.
      match /_private/{doc} {
        allow read, write: if isTutorOrAdmin();
      }

      match /submissions/{submissionId} {
        allow read: if canReadStudent(studentId);

        allow create: if isLinkedToStudent(studentId)
          && request.resource.data.status == 'draft';

        allow update: if isLinkedToStudent(studentId)
          && resource.data.status == 'draft'
          && request.resource.data.status in ['draft', 'submitted']
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['status', 'responses', 'updatedAt', 'submittedAt']);

        // Tutor/admin override — must come after the student-scoped
        // rules so the stricter student conditions are evaluated first.
        allow write:  if isTutorOrAdmin();
        allow delete: if isTutorOrAdmin();
      }

      // ── Per-worksheet submissions (Session 18A) ──────────────────────
      // Each PSM (assignment) can have one worksheetSubmission doc per
      // worksheet. Same access semantics as /submissions but scoped to
      // assignments/{aid}/worksheetSubmissions/{wsId}. doc id == wsId so
      // collisions are impossible. The status field gates the same
      // draft → submitted lifecycle. The onWorksheetSubmissionSubmit
      // trigger writes scoreCorrect/scoreTotal/perQuestion/status:graded
      // via Admin SDK.
      match /assignments/{aid}/worksheetSubmissions/{wsId} {
        allow read: if canReadStudent(studentId);

        allow create: if isLinkedToStudent(studentId)
          && request.resource.data.status == 'draft';

        allow update: if isLinkedToStudent(studentId)
          && resource.data.status == 'draft'
          && request.resource.data.status in ['draft', 'submitted']
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['status', 'responses', 'updatedAt', 'submittedAt']);

        allow write:  if isTutorOrAdmin();
        allow delete: if isTutorOrAdmin();
      }
    }

  }
}
